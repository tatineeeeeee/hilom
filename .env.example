# Server
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hilom
# Required in production. Must be >= 32 chars. Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=hilom-access-secret-change-in-prod
JWT_REFRESH_SECRET=hilom-refresh-secret-change-in-prod
PORT=4000
CLIENT_URL=http://localhost:5173
PAYMONGO_SECRET_KEY=sk_test_xxx
# Required for webhook signature verification when PAYMONGO_SECRET_KEY is set
PAYMONGO_WEBHOOK_SECRET=

# Resend (transactional email). Required in production; leave blank in dev (Maildev catches mail).
RESEND_API_KEY=

# Client
VITE_API_URL=http://localhost:4000/api
VITE_SOCKET_URL=http://localhost:4000
