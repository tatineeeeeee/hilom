{
  "name": "server",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "db:push": "drizzle-kit push",
    "db:push:test": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5432/hilom_test drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "db:seed:doctor": "tsx src/db/seedDoctor.ts",
    "db:seed:admin": "tsx src/db/seedAdmin.ts"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.1",
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "helmet": "^8.1.0",
    "rate-limit-redis": "^4.2.0",
    "redis": "^5.1.0",
    "swagger-ui-express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "pg": "^8.13.3",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/pg": "^8.11.11",
    "@types/swagger-ui-express": "^4.1.7",
    "drizzle-kit": "^0.30.5",
    "socket.io-client": "^4.8.3",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
