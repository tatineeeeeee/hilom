{
  "name": "hilom",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "e2e"
  ],
  "scripts": {
    "dev": "bun run --filter client dev & bun run --filter server dev",
    "typecheck": "bun run --filter client typecheck && bun run --filter server typecheck",
    "lint": "bun run --filter client lint && bun run --filter server lint",
    "test": "bun run --filter server test && bun run --filter client test",
    "test:e2e": "bun run --filter e2e test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "client/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "server/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^7.2.0",
    "client": "workspace:*",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "lint-staged": "^16.4.0",
    "maildev": "^2.2.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "server": "workspace:*",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "typescript-eslint": "^8.59.1"
  },
  "dependencies": {
    "nodemailer": "^8.0.7",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "resend": "^6.12.2",
    "sonner": "^2.0.7"
  }
}
